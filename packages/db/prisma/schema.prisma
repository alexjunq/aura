// AURA Prisma schema.
// Phase 0: tenant, user, NextAuth tables.
// Later phases add: material, supplier, piece, channel, buyer, sale, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One artisan's workspace. All domain rows are scoped by tenantId.
/// v1 invariant: exactly one user per tenant; the schema permits N:1 to ease
/// the future multi-user-per-tenant migration.
model Tenant {
  id               String   @id @default(cuid())
  name             String
  baseCurrency     String   @default("USD") // ISO 4217
  hourlyLaborRate  Decimal  @default(0) @db.Decimal(14, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users              User[]
  materials          Material[]
  materialPrices     MaterialPrice[]
  suppliers          Supplier[]
  pieces             Piece[]
  workSessions       WorkSession[]
  pieceStatusHistory PieceStatusHistory[]
  sales              Sale[]
  salesChannels      SalesChannel[]
  buyers             Buyer[]
  buyerInteractions  BuyerInteraction[]

  @@map("tenant")
}

/// An authenticated human. In v1 each tenant has exactly one user.
/// Email is globally unique in v1 — this will move to (tenant_id, email) when
/// multi-user-per-tenant ships.
model User {
  id              String    @id @default(cuid())
  tenantId        String
  email           String    @unique
  name            String?
  hashedPassword  String?
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts Account[]
  sessions Session[]

  @@index([tenantId])
  @@map("user")
}

// --- NextAuth (Auth.js) tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

// --- Phase 2: Materials & Suppliers ---

enum MaterialKind {
  commodity
  gemstone
  wood
  other

  @@map("material_kind")
}

enum MaterialPriceSource {
  manual
  feed
  supplier

  @@map("material_price_source")
}

model Material {
  id                  String       @id @default(cuid())
  tenantId            String
  name                String
  unit                String       // free-text unit symbol: g, ct, mm, piece, m, ...
  kind                MaterialKind @default(other)
  commoditySymbol     String?      // required when kind = commodity (XAU/XAG/...)
  notes               String?
  active              Boolean      @default(true)
  lastFeedFetchedAt   DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prices            MaterialPrice[]
  supplierMaterials SupplierMaterial[]
  pieceMaterials    PieceMaterial[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("material")
}

model MaterialPrice {
  id              String              @id @default(cuid())
  tenantId        String
  materialId      String
  source          MaterialPriceSource
  supplierId      String?             // required iff source='supplier' (CHECK in migration)
  pricePerUnit    Decimal             @db.Decimal(14, 4)
  currency        String              // ISO 4217
  fxRateToBase    Decimal             @db.Decimal(14, 8)
  effectiveAt     DateTime            @default(now())
  createdByUserId String?             // nullable for feed-sourced prices
  createdAt       DateTime            @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  material Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([materialId, effectiveAt(sort: Desc)])
  @@index([materialId, source, supplierId, effectiveAt(sort: Desc)])
  @@map("material_price")
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  address     Json?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierMaterials SupplierMaterial[]
  materialPrices    MaterialPrice[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("supplier")
}

model SupplierMaterial {
  supplierId          String
  materialId          String
  sku                 String?
  defaultLeadTimeDays Int?
  createdAt           DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@id([supplierId, materialId])
  @@index([materialId])
  @@map("supplier_material")
}

// --- Phase 3: Pieces, work sessions, status history ---

enum PieceStatus {
  in_progress
  in_studio
  reserved
  on_sale
  sold
  returned
  lost_damaged

  @@map("piece_status")
}

model Piece {
  id                  String      @id @default(cuid())
  tenantId            String
  title               String
  slug                String
  description         String?
  category            String?
  status              PieceStatus @default(in_progress)
  // Free-form studio location label (e.g. "Shelf B").
  // Channel context comes from piece_status_history; never on the row.
  currentLocationText String?
  primaryPhotoKey     String?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials     PieceMaterial[]
  workSessions  WorkSession[]
  statusHistory PieceStatusHistory[]
  sales         Sale[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("piece")
}

model PieceMaterial {
  pieceId              String
  materialId           String
  quantity             Decimal  @db.Decimal(14, 4)
  // Frozen at the moment the material was added; historical cost stable.
  capturedPricePerUnit Decimal  @db.Decimal(14, 4) // in base currency
  capturedAt           DateTime @default(now())

  piece    Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@id([pieceId, materialId])
  @@index([pieceId])
  @@index([materialId])
  @@map("piece_material")
}

model WorkSession {
  id              String    @id @default(cuid())
  tenantId        String
  pieceId         String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  note            String?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  piece  Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([pieceId])
  @@map("work_session")
}

model PieceStatusHistory {
  id         String      @id @default(cuid())
  tenantId   String
  pieceId    String
  fromStatus PieceStatus
  toStatus   PieceStatus
  changedAt  DateTime    @default(now())
  userId     String?
  context    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  piece  Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@index([pieceId])
  @@index([pieceId, changedAt(sort: Desc)])
  @@map("piece_status_history")
}

// --- Phase 4: Sales channels ---

enum SalesChannelType {
  online
  physical_store
  event
  direct
  reseller

  @@map("sales_channel_type")
}

model SalesChannel {
  id            String           @id @default(cuid())
  tenantId      String
  name          String
  type          SalesChannelType @default(direct)
  commissionPct Decimal          @default(0) @db.Decimal(5, 2) // 0–100
  contactName   String?
  email         String?
  phone         String?
  address       Json?
  notes         String?
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("sales_channel")
}

// --- Phase 5: Buyers & interactions ---

enum BuyerInteractionKind {
  meeting
  message
  inquiry
  note
  other

  @@map("buyer_interaction_kind")
}

model Buyer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  instagram String?
  birthdate DateTime? @db.Date
  address   Json?
  interests String[]
  notes     String?
  retiredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interactions BuyerInteraction[]
  sales        Sale[]

  @@index([tenantId])
  @@index([tenantId, retiredAt])
  @@map("buyer")
}

model BuyerInteraction {
  id              String               @id @default(cuid())
  tenantId        String
  buyerId         String
  occurredAt      DateTime
  kind            BuyerInteractionKind @default(note)
  summary         String
  createdByUserId String?
  createdAt       DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buyer  Buyer  @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId, occurredAt(sort: Desc)])
  @@map("buyer_interaction")
}

// --- Phase 6: Sales ---

model Sale {
  id                     String    @id @default(cuid())
  tenantId               String
  pieceId                String
  buyerId                String
  channelId              String
  salePrice              Decimal   @db.Decimal(14, 4)
  currency               String
  fxRateToBase           Decimal   @db.Decimal(14, 8)
  commissionPctSnapshot  Decimal   @db.Decimal(5, 2)
  commissionAmount       Decimal   @db.Decimal(14, 4)
  netAmount              Decimal   @db.Decimal(14, 4)
  soldAt                 DateTime
  refundedAt             DateTime?
  notes                  String?
  createdAt              DateTime  @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  piece   Piece        @relation(fields: [pieceId], references: [id], onDelete: Restrict)
  buyer   Buyer        @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  channel SalesChannel @relation(fields: [channelId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, soldAt(sort: Desc)])
  @@index([buyerId, soldAt(sort: Desc)])
  @@index([channelId, soldAt(sort: Desc)])
  @@map("sale")
}
