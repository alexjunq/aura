{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "description": "AURA — Artisan Unique-piece Registry & Accounting",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "VITEST_SCOPE=unit vitest run",
    "test:integration": "VITEST_SCOPE=integration vitest run",
    "test:watch": "VITEST_SCOPE=unit vitest",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @aura/db generate",
    "db:migrate": "pnpm --filter @aura/db migrate",
    "db:reset": "pnpm --filter @aura/db reset"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
