## AURA environment variables.
## Copy to `.env` and fill in. `pnpm dev` + `docker compose up` use this.

NODE_ENV=development
LOG_LEVEL=debug

# Database (matches docker-compose.yml dev defaults)
DATABASE_URL=postgresql://aura:aura@localhost:5432/aura?schema=public

# Auth.js — generate via: openssl rand -base64 48
NEXTAUTH_SECRET=replace-me-with-at-least-32-chars-of-random
NEXTAUTH_URL=http://localhost:3000

# Email (dev: smtp -> mailhog at localhost:1025)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@aura.local
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
# For prod, switch EMAIL_PROVIDER to "resend" and set EMAIL_API_KEY.

# OAuth (optional in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Object storage (matches docker-compose.yml dev defaults)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aura-dev
S3_ACCESS_KEY=auraminio
S3_SECRET_KEY=auraminio-secret
S3_FORCE_PATH_STYLE=true

# External price feeds
COMMODITY_PROVIDER=fake
COMMODITY_API_KEY=
FX_PROVIDER=fake

# Ports
WEB_PORT=3000
WORKER_PORT=3001
